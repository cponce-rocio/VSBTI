# URL de la API para producción en Vercel
# IMPORTANTE: Esta variable DEBE configurarse en Vercel Dashboard
# Settings > Environment Variables > VITE_API_URL
# Ejemplo: https://vsbti-api-production.railway.app/api

# Si no está configurada, el frontend cargará datos de ejemplo locales automáticamente
VITE_API_URL=https://vsbti-api-production.railway.app/api

